[fetch]
prune = true
pruneTags = true

[init]
defaultBranch = "main"

[pull]
rebase = true

[push]
default = "current"

[rebase]
autoSquash = true
autoStash = true

[color]
ui = true

[core]
pager = delta

[interactive]
diffFilter = delta --color-only

[delta]
navigate = true  # use n and N to move between diff sections
dark = true      # or light = true, or omit for auto-detection

[merge]
conflictstyle = zdiff3

[alias]
track = "!f() { git branch --set-upstream-to=origin/\"$1\" \"$1\"; }; f"

{{ printf "\n" -}}
{{- if eq .class "work" -}}
    {{- template "work/git_config.tmpl" . -}}
{{- else if eq .class "personal" -}}
    {{- template "personal/git_config.tmpl" . -}}
{{- end -}}